# DO NOT paste secrets into chat.
# Put your real values in a local `.env` file (not committed).

# Server
PORT=3001
MONGODB_URI=your_mongodb_connection_string_here

# Gemini (Google AI Studio / Google GenAI)
# Multiple API keys for automatic rotation - UNLIMITED keys supported!
# System auto-detects all GOOGLE_API_KEY* variables (GOOGLE_API_KEY, GOOGLE_API_KEY1, GOOGLE_API_KEY2, etc.)
# Randomly selects one key per request and logs last 6 characters for tracking
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY1=your_second_api_key_here
GOOGLE_API_KEY2=your_third_api_key_here
GOOGLE_API_KEY3=
GOOGLE_API_KEY4=
GOOGLE_API_KEY5=

GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_VERSION=v1beta

# App
DEFAULT_USER_ID=local-user
